generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Hotel {
  id         BigInt    @id @default(autoincrement())
  name       String
  totalRooms Int       @map("total_rooms")
  bookings   Booking[]

  @@map("hotels")
}

model Booking {
  id       BigInt   @id @default(autoincrement())
  hotelId  BigInt   @map("hotel_id")
  guestId  BigInt   @map("guest_id")
  checkIn  DateTime @map("check_in") @db.Timestamptz
  checkOut DateTime @map("check_out") @db.Timestamptz

  // A `created_at` column adds a layer of complexity to generating realistic seed data that
  // is not worth it right now.
  // However, it could be interesting to implement this in the future as it opens up new areas
  // for inquiry like: average number of days between booking creation and check in.
  // createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  hotel Hotel @relation(fields: [hotelId], references: [id])
  guest Guest @relation(fields: [guestId], references: [id])

  @@map("bookings")
}

// You can imagine that some guests are users of the application but not all users are guests.
// This enables a "check out as guest" workflow.
model Guest {
  id        BigInt    @id @default(autoincrement())
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  email     String
  bookings  Booking[]
  // Add nullable user ID if/when users are added in the future.

  @@map("guests")
}
