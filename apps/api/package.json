{
  "name": "api",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "source .env && tsx --watch src/index.ts",
    "test:seed": "vitest --dir ./prisma/__tests__",
    "db:start": "docker compose --env-file .env up -d",
    "db:generate": "dotenv -e .env -- prisma generate",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:studio": "dotenv -e .env -- prisma studio",
    "db:seed": "dotenv -e .env -- prisma db seed",
    "db:validate": "dotenv -e .env -- prisma validate"
  },
  "dependencies": {
    "@datastructures-js/heap": "github:datastructures-js/heap",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "cors": "^2.8.6",
    "express": "5.2.1",
    "morgan": "^1.11.0",
    "pg": "8.21.0",
    "pg-copy-streams": "^7.0.0",
    "temporal-polyfill": "^0.3.2",
    "vitest": "^4.1.8"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@repo/numbers": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/cors": "^2.8.19",
    "@types/express": "5.0.5",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/morgan": "^1.9.10",
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "@types/pg-copy-streams": "^1.2.5",
    "dotenv": "17.3.1",
    "dotenv-cli": "^11.0.0",
    "prisma": "7.8.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
